{
  "name": "Kubernetes AI Sandbox",
  "image": "://microsoft.com",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:1": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest"
    }
  },
  "postCreateCommand": "curl -Lo ./kind https://k8s.io && chmod +x ./kind && sudo mv ./kind /usr/local/bin/kind",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-azuretools.vscode-docker",
        "ms-python.python"
      ]
    }
  }
}
